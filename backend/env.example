# OpenTelemetry Tracing Configuration
JAEGER_HOST=localhost
JAEGER_PORT=4317
ENABLE_CONSOLE_EXPORTER=true

# Backend Configuration
DEBUG=true
LOG_LEVEL=info

# A2A Agent Configuration (AgentGateway base URL)
SUPPLY_CHAIN_AGENT_URL=http://localhost:3000/supply-chain-agent

# Auth0 Configuration
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=

# Server Configuration
HOST=0.0.0.0
PORT=8000

# CORS Configuration
CORS_ALLOW_ALL=true
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3050,http://127.0.0.1:3000,http://127.0.0.1:3050,http://localhost:5173,http://127.0.0.1:5173
