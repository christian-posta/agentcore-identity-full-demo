# OpenTelemetry Tracing Configuration
JAEGER_HOST=jaeger-collector.istio-system
JAEGER_PORT=4317
ENABLE_CONSOLE_EXPORTER=false

# Backend Configuration
DEBUG=true
LOG_LEVEL=info

# A2A Agent Configuration
SUPPLY_CHAIN_AGENT_URL=http://supply-chain-agent.default/

# Agent STS Configuration
AGENT_STS_URL=http://agent-sts.default:8081
BACKEND_SPIFFE_ID=spiffe://cluster.local/ns/default/sa/supply-chain-backend

# Auth0 Configuration
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=

# CORS Configuration
CORS_ALLOW_ALL=true

